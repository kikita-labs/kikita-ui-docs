{
  "name": "kikita-ui-docs",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node tools/generate-example-sources.mjs && ng serve",
    "build": "node tools/generate-example-sources.mjs --check && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "node tools/generate-example-sources.mjs --check && ng test",
    "generate:examples": "node tools/generate-example-sources.mjs",
    "check:generated": "node tools/generate-example-sources.mjs --check",
    "check:inventory": "node tools/check-component-inventory.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:boundaries": "node tools/check-boundaries.mjs",
    "check:package-consumer": "node tools/check-package-consumer.mjs",
    "check:performance": "node tools/check-performance-budgets.mjs",
    "check:migration-debt": "node tools/check-migration-debt.mjs",
    "generate:agent-surface": "node tools/generate-agent-surface.mjs",
    "check:agent-surface": "node tools/generate-agent-surface.mjs --check",
    "check:mcp": "node mcp/scripts/smoke.mjs",
    "publish": "npm run publish:mcp",
    "publish:mcp": "npm run generate:agent-surface && npm run check:mcp && npm publish ./mcp --access public --@kikita-labs:registry=https://registry.npmjs.org/",
    "lint": "node tools/generate-example-sources.mjs --check && ng lint",
    "test:e2e": "playwright test --project=e2e",
    "test:a11y": "playwright test --project=a11y",
    "test:responsive": "playwright test --project=responsive",
    "test:visual": "playwright test --project=visual",
    "test:browser": "playwright test",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "serve:ssr:kikita-ui-docs": "node dist/kikita-ui-docs/server/server.mjs"
  },
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.5",
    "@kikita-labs/ui": "0.5.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "22.0.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.1",
    "shiki": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.scss": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
